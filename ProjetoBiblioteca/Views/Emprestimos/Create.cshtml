@model ProjetoBiblioteca.ViewModels.EmprestimoFormVM
@using ProjetoBiblioteca.Models

@* Tela utilizada para registrar um novo empréstimo. *@
@{
    ViewData["Title"] = "Novo Empréstimo";

    var usuarios =
        (IEnumerable<Usuario>)ViewBag.Usuarios;

    var livros =
        (IEnumerable<Livro>)ViewBag.Livros;
}

<h1>Novo Empréstimo</h1>

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger">
        @TempData["Erro"]
    </div>
}

<form asp-action="Create" method="post">

    <div asp-validation-summary="ModelOnly"
         class="text-danger">
    </div>

    <div class="mb-3">
        <label asp-for="UsuarioId"
               class="form-label"></label>

        <select asp-for="UsuarioId"
                class="form-select">

            <option value="">
                -- selecione --
            </option>

            @foreach (var usuario in usuarios)
            {
                <option value="@usuario.Id">
                    @usuario.NomeCompleto
                </option>
            }

        </select>

        <span asp-validation-for="UsuarioId"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LivroId"
               class="form-label"></label>

        <select asp-for="LivroId"
                class="form-select">

            <option value="">
                -- selecione --
            </option>

            @foreach (var livro in livros)
            {
                <option value="@livro.Id">
                    @livro.NomeLivro
                </option>
            }

        </select>

        <span asp-validation-for="LivroId"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DataEmprestimo"
               class="form-label"></label>

        <input asp-for="DataEmprestimo"
               type="date"
               class="form-control" />

        <span asp-validation-for="DataEmprestimo"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="DataPrevistaDevolucao"
               class="form-label"></label>

        <input asp-for="DataPrevistaDevolucao"
               type="date"
               class="form-control" />

        <span asp-validation-for="DataPrevistaDevolucao"
              class="text-danger"></span>
    </div>

    <button type="submit"
            class="btn btn-primary">
        Salvar
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Voltar
    </a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync(
            "_ValidationScriptsPartial");
    }
}