@model ProjetoBiblioteca.Models.Usuario

@* Tela de confirmação para exclusão de usuários. *@
@{
    ViewData["Title"] = "Excluir";
}

<h1>Excluir Usuário</h1>

<h3>Deseja realmente excluir?</h3>

<hr />

<dl class="row">

    <dt class="col-sm-3">Nome</dt>
    <dd class="col-sm-9">
        @Model.NomeCompleto
    </dd>

    <dt class="col-sm-3">Data de Nascimento</dt>
    <dd class="col-sm-9">
        @Model.DataNascimento.ToString("dd/MM/yyyy")
    </dd>

    <dt class="col-sm-3">E-mail</dt>
    <dd class="col-sm-9">
        @Model.Email
    </dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @(Model.Status ? "Ativo" : "Inativo")
    </dd>

</dl>

<form asp-action="Delete" method="post">

    <input type="hidden" asp-for="Id" />

    <button type="submit"
            class="btn btn-danger">
        Excluir
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancelar
    </a>

</form>
