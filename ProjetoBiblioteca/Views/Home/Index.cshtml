@{
    ViewData["Title"] = "Home";
}

<h2 class="mb-4">Dados da Biblioteca</h2>

<div class="row">

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow">
            <div class="card-body">
                <h5>Usuários</h5>
                <h2>@ViewBag.TotalUsuarios</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow">
            <div class="card-body">
                <h5>Livros</h5>
                <h2>@ViewBag.TotalLivros</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow">
            <div class="card-body">
                <h5>Disponíveis</h5>
                <h2>@ViewBag.TotalDisponiveis</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card text-center shadow">
            <div class="card-body">
                <h5>Empréstimos ativos</h5>
                <h2>@ViewBag.TotalEmprestimos</h2>
            </div>
        </div>
    </div>

</div>