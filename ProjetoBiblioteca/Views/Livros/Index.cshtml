@model IEnumerable<ProjetoBiblioteca.Models.Livro>

@{
    ViewData["Title"] = "Livros";
    var busca = ViewData["busca"] as string ?? "";
}

@await Html.PartialAsync("_Alerts")

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="m-0">Livros</h1>

    <a asp-action="Create" class="btn btn-primary">
        Novo Livro
    </a>
</div>

<form method="get" class="mb-3">
    <div class="input-group">

        <input type="text"
               class="form-control"
               name="busca"
               value="@busca"
               placeholder="Buscar livro..." />

        <button class="btn btn-outline-primary" type="submit">
            Buscar
        </button>

        @if (!string.IsNullOrWhiteSpace(busca))
        {
            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Limpar
            </a>
        }

    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Nome</th>
            <th>Autor</th>
            <th>Estoque</th>
            <th>Faixa Etária</th>
            <th>Categoria</th>
            <th>Ano</th>
            <th></th>
        </tr>
        </thead>

        <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <td>@item.NomeLivro</td>

                <td>@item.Autor</td>

                <td>@item.QuantidadeEstoque</td>

                <td>@item.FaixaEtariaPermitida</td>

                <td>@item.Categoria</td>

                <td>@item.AnoPublicacao</td>

                <td class="text-end">

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-info">
                        Detalhes
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-warning">
                        Editar
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-sm btn-danger">
                        Excluir
                    </a>

                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<nav class="mt-3">
    <ul class="pagination">

        @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
        {
            <li class="page-item @(i == ViewBag.PaginaAtual ? "active" : "")">

                <a class="page-link"
                   asp-action="Index"
                   asp-route-pagina="@i"
                   asp-route-busca="@ViewBag.Busca">

                    @i

                </a>

            </li>
        }

    </ul>
</nav>